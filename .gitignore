# =========================
# GLOBAL WILDCARDS (Safety Net)
# =========================
node_modules/
dist/
dist-ssr/
venv/
.venv/
env/
__pycache__/
*.py[cod]
*$py.class
*.db
*.sqlite
*.sqlite3
omnimind.db
.env
.env.*
!.env.example
*.log
storage/
uploads/

# =========================
# FRONTEND (Explicit)
# =========================
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/*.local
frontend/.env
frontend/.env.*
!frontend/.env.example
frontend/.firebase/
frontend/firebase-debug.log*
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*

# =========================
# BACKEND (Explicit)
# =========================
backend/venv/
backend/.venv/
backend/env/
backend/__pycache__/
backend/*.py[cod]
backend/*$py.class
backend/.env
backend/.env.*
!backend/.env.example
backend/*.log
backend/storage/
backend/uploads/
backend/*.db
backend/*.sqlite
backend/*.sqlite3
backend/omnimind.db
package-lock.json